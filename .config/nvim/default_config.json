{
  "plugins": {
    "animation": {
      "enabled": false
    },
    "complement": {
      "enabled": true,
      "engine": "blink-cmp"
    },
    "file_explorer": {
      "name": "yazi"
    },
    "fuzzy_finder": {
      "telescope": {
        "0find_command": [
          "rg",
          "--files",
          "--hidden",
          "--no-ignore",
          "--glob",
          "!.git/*",
          "--glob",
          "!*.cache/*",
          "--glob",
          "!.venv/*",
          "--glob",
          "!*.pyc",
          "--glob",
          "!.obsidian/*",
          "--glob",
          "!*.DS_Store"
        ],
        "find_command": [
          "rg",
          "--files",
          "--hidden",
          "--glob",
          "!.git/*",
          "--glob",
          "!.venv/*",
          "--glob",
          "!*.pyc",
          "--glob",
          "!.obsidian/*",
          "--glob",
          "!*.DS_Store"
        ]
      }
    },
    "inputBehavior": {
      "hardtime": {
        "enabled": false
      }
    },
    "rest": {
      "enabled": false
    },
    "rsync": {
      "transfer": {
        "upload_rsync_params": [
          "-rlzi",
          "--checksum",
          "--exclude",
          ".git",
          "--exclude",
          ".idea",
          "--exclude",
          ".DS_Store",
          "--exclude",
          ".nvim",
          "--exclude",
          "*.pyc"
        ],
        "download_rsync_params": [
          "-rlzi",
          "--checksum",
          "--exclude",
          ".git"
        ]
      }
    }
  },
  "format": {
    "format_on_save": true
  },
  "colorscheme": {
    "name": "vim",
    "opt": {}
  }
}
