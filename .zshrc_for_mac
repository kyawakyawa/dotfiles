eval "$(starship init zsh)"

# cli toolの補完ファイル置き場（compinit より前！）
fpath=(~/.zsh/completions $fpath)

# 補完の初期化 #########################################

# 1. zshの補完機能を初期化 (Sheldonの読み込み前に行う)
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.m-1) ]]; then
  compinit
else
  compinit -C
fi

